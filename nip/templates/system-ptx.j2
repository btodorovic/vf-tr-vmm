{% if (mgmt_ri_knob is defined) and {mgmt_ri_knob is not None) %}
interfaces {                                          ### Only if OOB MGMT is used, otherwise omit
    re0:mgmt-0 {
        unit 0 {
            family inet {
                address {{ fxp0.vip }}/{{ fxp0.preflen }} {
                    master-only;
                }
                address {{ fxp0.re0 }}/{{ fxp0.preflen }};
                inactive: filter input FF-RE-MGMT-V4;
            }
        }
    }
    re1:mgmt-0 {
        unit 0 {
            family inet {
                address {{ fxp0.vip }}/{{ fxp0.preflen }} {
                    master-only;
                }
                address {{ fxp0.re1 }}/{{ fxp0.preflen }};
                inactive: filter input FF-RE-MGMT-V4;
            }
        }
    }
}
{% endif %}
system {
    host-name {{ hostname }};
    trace application {
        all {
            node {
                re0 level emergency;
                re1 level emergency;
                fpc0 level emergency;
                fpc1 level emergency;
                fpc2 level emergency;
                fpc3 level emergency;
                fpc4 level emergency;
                fpc5 level emergency;
                fpc6 level emergency;
                fpc7 level emergency;
            }
        }
    }
}
{% if (mgmt_ri_knob is defined) and {mgmt_ri_knob is not None) %}
system {
    management-instance;                               ### Enables routing-instance mgmt_junos (OOB MGMT ONLY!)
}
routing-instances {
    mgmt_junos {
        routing-options {
            static {
                route 0.0.0.0/0 {
                    next-hop {{ fxp0.gw }};                 ### Default gateway on the OOB DCN LAN segment
                    retain;
                    no-readvertise;
                }
            }
        }
    }
}
{% endif %}
chassis { 
    aggregated-devices {                       
        ethernet {	
            device-count 128;
        } 
        maximum-links 64;
    }
}
forwarding-options {
    microbfd-bypass-route-lookup;              # Only on PTX
}
firewall {
    family inet {
        filter FF-RE-MGMT-V4 {
            interface-specific;
            term TR-NTP-ok {
                from {
                    source-prefix-list {
                        PL-NTP-SERVERS;
                        PL-NTP-SOURCE;
                    }
                    protocol udp;
                    port ntp;
                }
                then {
                    policer PC-ntp;
                    count CNT-NTP-ok;
                    accept;
                }
            }
            term TR-SNMP-udp-ok {
                from {
                    source-prefix-list {
                        PL-SNMP;
                    }
                    protocol udp;
                    destination-port snmp;
                }
                then {
                    policer PC-snmp-udp;
                    count CNT-SNMP-udp-ok;
                    accept;
                }
            }
            term TR-SNMP-tcp-ok {
                from {
                    source-prefix-list {
                        PL-SNMP;
                    }
                    protocol tcp;
                    destination-port snmp;
                }
                then {
                    policer PC-snmp-tcp;
                    count CNT-SNMP-tcp-ok;
                    accept;
                }
            }
            term TR-SSH-ok {
                from {
                    source-prefix-list {
                        PL-SSH-CLIENTS;
                    }
                    protocol tcp;
                    port ssh;
                }
                then {
                    policer PC-ssh;
                    count CNT-SSH-ok;
                    accept;
                }
            }
            term TR-NETCONF-ok {
                from {
                    source-prefix-list {
                        PL-SSH-CLIENTS;
                    }
                    protocol tcp;
                    destination-port 830;
                }
                then {
                    policer PC-netconf;
                    count CNT-NETCONF-ok;
                    accept;
                }
            }
            term TR-DNS-ok {
                from {
                    source-prefix-list {
                        PL-DNS-SERVERS;
                    }
                    protocol udp;
                    port domain;
                }
                then {
                    policer PC-dns;
                    count CNT-DNS-ok;
                    accept;
                }
            }
            term TR-ICMP-POLICE-ok {
                from {
                    protocol icmp;
                    icmp-type [ echo-request echo-reply unreachable time-exceeded parameter-problem ];
                }
                then {
                    policer PC-icmp;
                    count CNT-ICMP-POLICE;
                    accept;
                }
            }
            term TR-TRACEROUTE-ok {
                from {
                    protocol udp;
                    destination-port 33434-33523;
                }
                then {
                    policer PC-traceroutes;
                    count CNT-TRACEROUTE-ok;
                    accept;
                }
            }
            term TR-DISCARD-UNDEFINED {
                then {
                    count CNT-DISCARD-UNDEFINED;
                    discard;
                }
            }
        }
    }
}
