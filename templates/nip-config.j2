    GR-EDGE-INTF-L2 {
        interfaces {
            <ae*> {
                aggregated-ether-options {
                    lacp {
                        active; 
                    }
                }
            }
            "<[egx][te]-*>" {
                optics-options {
                    alarm low-light-alarm {
                        syslog;
                    }
                    warning low-light-warning {
                        syslog;
                    }
                }
            }
            <*> {
                traps;
                mtu 9192;
                hold-time up 2000 down 0;
                unit <*> {
                    traps;
                }
            }
        }
    }
}
chassis { 
    aggregated-devices {                       
        ethernet {  
            device-count 128;
        } 
        maximum-links 64;
    }
}
forwarding-options {
    microbfd-bypass-route-lookup;              # Only on PTX
}
interfaces {
    lo0 {
        inactive: apply-groups GR-FF-RE-PROTECT;
        unit 0 {
            family inet {
                address {{ lo0.ip }}/32 {
                    primary;
                    preferred;
                }
                address {{ lo0.ip1 }}/32;
            }
            family iso {
                address {{ lo0.clns }};
            }
