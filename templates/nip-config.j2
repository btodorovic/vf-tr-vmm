{% if 'RR41' in hostname %}
protocols {
    bgp {
        group GR-IBGP-RR {
            type internal;
            description "IBGP Full Mesh for RR1s";
            tcp-mss 4096;
            authentication-key "{{ bgp.key }}";
            export PS-IBGP-RR-EXPORT;
            family inet {
                labeled-unicast {
                    rib-group RG-REMOTE-LOOPBACKS;
                    add-path {
                        send {
                            path-count 2;
                        }
                    }
                    per-prefix-label;
                    rib {
                        inet.3;
                    }
                }
            }
            family inet-vpn unicast;
            family inet6-vpn unicast;
            neighbor 10.100.104.1 description "ROBUC1RR41";
            neighbor 10.100.104.3 description "ROCLU1RR41";
            neighbor 10.100.104.5 description "ROBUC2RR41";
            delete: neighbor {{ lo0.ip }};
        }
        group GR-RRC-PE {
            apply-groups GR-BGP-VPN-ADD-PATH-SEND;
            type internal;
            description "CPN PE routers";
            tcp-mss 4096;
            authentication-key "{{ bgp.key }}";
            cluster {{ lo0.ip }};                                   # Primary lo0.0 IP address of the RR
            local-address {{ lo0.ip }};                             # Same as previous
            family inet {
                labeled-unicast {
                    rib-group RG-REMOTE-LOOPBACKS;
                    add-path {
                        send {
                            path-count 2;
                        }
                    }
                    per-prefix-label;
                    rib {
                        inet.3;
                    }
                }
            }
            family inet-vpn unicast;
            family inet6-vpn unicast;
            vpn-apply-export;
            import PS-IBGP-PE-IMPORT;
            export PS-IBGP-PE-EXPORT;
            neighbor 10.100.104.21 description "ROBUC1PE41";
            neighbor 10.100.104.22 description "ROBUC1PE42";
            neighbor 10.100.104.23 description "ROBUC2PE41";
