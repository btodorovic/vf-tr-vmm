# ------------------------------------------------------------------------------------ #
#   Chapter 6.12 - LLDP                                                                #
# ------------------------------------------------------------------------------------ #
protocols {
    lldp {
        ptopo-configuration-trap-interval 60;
        lldp-configuration-notification-interval 60;
        port-id-subtype interface-name;
        interface all {
            disable;
        }
{% for ifd in interfaces %}{% if ifd.lag_members is defined or ifd.ifd[0:2]=='em' %}
        interface {{ ifd.ifd }};
{% endif %}{% endfor %}
    }
}
# ------------------------------------------------------------------------------------ #
#   Chapter 7 - COMMON ROUTING OPTIONS                                                 #
# ------------------------------------------------------------------------------------ #
routing-options {           
    router-id {{ lo0.ip }};
    autonomous-system 12302;
    forwarding-table {
        export PS-LOAD-BALANCE;
    }
    interface-routes {
        rib-group inet RG-LOCAL-LOOPBACKS;
    }
    rib-groups {
        RG-LOCAL-LOOPBACKS {
            import-rib [ inet.0 inet.3 ];
            import-policy PS-MY-LOCAL-LOOPBACK;
        }
        RG-REMOTE-LOOPBACKS {
            import-rib [ inet.3 inet.0 inet6.3 ];
        }
    }
}
policy-options {    
    policy-statement PS-LOAD-BALANCE {  
        term NO-LB-ISIS {
            from protocol isis;
            then accept;
        }
        term OTHER {
            then {  
                load-balance per-packet;    
            }
        }
    }
    policy-statement PS-MY-LOCAL-LOOPBACK {
        term LOCAL-LOOPBACKS {
            from {
                interface lo0.0;
                route-filter 10.100.104.0/24 prefix-length-range /32-/32;
            }
            to rib inet.3;
            then accept;
        }
        then reject;
    }
}
# ------------------------------------------------------------------------------------ #
#   Chapter 8 - IS-IS                                                                  #
# ------------------------------------------------------------------------------------ #
groups {
    GR-ISIS {
        protocols {
            isis {
                interface <*e*> {
                    level 2 {
                        post-convergence-lfa {
                            node-protection cost 16777214;
                            srlg-protection;
                        }
                    }
                    lsp-interval 10;
                    point-to-point;
                }
                level 1 disable;
                level 2 {
                    authentication-key "{{ isis.key }}";
                    authentication-type md5;
                    wide-metrics-only;
                }
                backup-spf-options {
                    use-post-convergence-lfa maximum-labels 8;
                    use-source-packet-routing;
                    per-prefix-calculation;
                }
                lsp-lifetime 65535;
                no-ipv6-routing;
                spf-options {
                    delay 50;
                    holddown 2000;
                    rapid-runs 5;
                }
            }
        }
    }
    GR-ISIS-IF-BFD {
        protocols {
            isis {
                interface <*e*> {
                    family inet {
                        bfd-liveness-detection {
                            minimum-interval 50;
                            multiplier 3;
                            no-adaptation;
                        }
                    }
                }
            }
        }
    }
}
protocols {
    isis {
        apply-groups GR-ISIS;
        export PS-ISIS-EXPORT;
        interface lo0.0 {
            passive;
        }
        source-packet-routing {
            srgb start-label 900000 index-range 99968;
            node-segment {
                ipv4-index {{ lo0.ip.split('.')[-1] }};
                ipv6-index {{ 600 + (lo0.ip.split('.')[-1]|int) }};
            }
        }
        traffic-engineering {
            igp-topology;
            advertisement always;
        }
        no-ipv6-routing;
        overload{% if 'RR' not in hostname %} timeout 300{% endif %};
{% for ifd in interfaces %}{% if ifd.isis is defined %}
        interface {{ ifd.ifd }}{% if 'RR' not in ifd.remote %}.0{% endif %} {    ## NBR: {{ ifd.remote }}
    {% if 'RR' in hostname or 'RR' in ifd.remote %}
            apply-groups GR-ISIS-IF-BFD;
    {% endif %}
            level 1 disable;
            level 2 metric {{ ifd.isis }};
        }
{% endif %}{% endfor %}        
    }
}
policy-options {
    policy-statement PS-ISIS-EXPORT {
        term TR-LOCAL-LOOPBACK {
            from {
                protocol direct;
                interface lo0.0;
                route-filter 0.0.0.0/0 prefix-length-range /32-/32;
            }
            then accept;
        }
{% if 'PE' in hostname %}
        term TR-SWITCH-MGMT {
            from {
                protocol static;
                route-filter 10.245.1.0/24 prefix-length-range /32-/32;
            }
            then accept;
        }
{% endif %}
    }
}
{% endif %}
{% if 'SW' not in hostname %}
