                unicast;
            }
            neighbor 10.100.104.1 description "ROBUC1RR41";
            neighbor 10.100.104.3 description "ROCLU1RR41";
            neighbor 10.100.104.5 description "ROBUC2RR41";
        }
        group GR-IBGP-RR2 {
            type internal;
            local-address {{ lo0.ip }};                             # Primary lo0.0 IP address of the RR
            tcp-mss 4096;
            authentication-key "{{ bgp.key }}";
            advertise-external;                                     # Always prefer external routes over internal
            vpn-apply-export;
            export PS-IBGP-RR2-EXPORT;
            family inet {
                labeled-unicast {
                    rib-group RG-REMOTE-LOOPBACKS;                  # Copy eTN_BB loopbacks from inet.3 to inet.0
                    rib inet.3;
                    add-path receive;
                    per-prefix-label;                               # Assign a separate label per each lo0 /32
                }
                unicast;
            }
            family inet-vpn {
                unicast {
                    add-path {
                        receive;
                        send {
                            path-count 4;
                        }
                    }
                }
            }
            family inet6-vpn {
                unicast {
                    add-path {
                        receive;
                        send {
                            path-count 4;
                        }
                    }
                }
            }
            family inet-mvpn signaling;
            family inet6-mvpn signaling;
            family evpn signaling;
            neighbor 10.100.104.2 description "ROBUC1RR42";
            neighbor 10.100.104.4 description "ROCLU1RR42";
            neighbor 10.100.104.6 description "ROBUC2RR42";
        }
        group GR-eTN-BB {
            type internal;
            authentication-key "{{ bgp.key }}";
            advertise-inactive;                                     # See 10.6.2
            cluster {{ lo0.ip }};                                   # Primary lo0.0 IP address of the RR
            local-address {{ lo0.ip }};                             # Primary lo0.0 IP address of the RR
            family inet {
                labeled-unicast {
                    rib-group RG-REMOTE-LOOPBACKS;                  # Copy eTN_BB loopbacks from inet.3 to inet.0
                    rib inet.3;
                    per-prefix-label;                               # Assign a separate label per each lo0 /32
                }
            }
            import PS-IBGP-BB-IMPORT;
            export PS-IBGP-BB-EXPORT;
    {% for BB in eTN_BB %}
            neighbor {{ BB.ip }} description "{{ BB.hostname }}";
    {% endfor %}
        }
        group GR-IBGP-PE-LOCAL {
            type internal;
            local-address {{ lo0.ip }};                             # Primary lo0.0 IP address of the RR
            import PS-IBGP-PE-LOCAL-IMPORT;
            family inet-vpn {
                unicast;
            }
            family inet6-vpn {
                unicast;
            }
            authentication-key "$9$4rZGiHqfn/tf5cleK8LgoJGkPz39ApB5QBE"; ## SECRET-DATA
            export PS-IBGP-PE-LOCAL-EXPORT;
            tcp-mss 4096;
            {% set host_id = hostname[-1]|int %}
            {% if host_id == 1 %}
            neighbor {{ lo0.ip.split('.')[0:3]|join('.') + '.' + (lo0.ip.split('.')[-1]|int+1)|string }} {
                description ROBRV1PE4{{ host_id + 1 }};
            }
            {% else %}
            neighbor {{ lo0.ip.split('.')[0:3]|join('.') + '.' + (lo0.ip.split('.')[-1]|int-1)|string }} {
                description ROBRV1PE4{{ host_id - 1 }};
            }
            {% endif %}
            vpn-apply-export;
        }
    }
}
policy-options {
    policy-statement PS-IBGP-PE-LOCAL-EXPORT {
        term BGP {
            from protocol bgp;
            then {
                next-hop self;
                accept;
            }
        }
    }
    policy-statement PS-IBGP-PE-LOCAL-IMPORT {
        term 5 {
            from community CM-12302:999;
            then accept;
        }
        then reject;
    }
    policy-statement PS-IBGP-BB-IMPORT {
        term BLOCK-LOOPS {
            from {
                protocol bgp;               
            }
            then {
                community add CM-LU-eTN-{{ site.alias }};
                accept;
            }
        }
    }
    policy-statement PS-IBGP-BB-EXPORT {
        term BLOCK-LOOPS {
            from {
                protocol bgp;
                rib inet.3;
                community CM-LU-eTN-{{ site.alias }};      ## If route is already received from eTN via other PE, block it
            }
            then reject;
        }
        term IPV4-LU {
            from {
                protocol [ bgp direct ];
                rib inet.3;
            }
            then {
                next-hop self;
                accept;
            }
        }
        then reject;
    }
    policy-statement PS-IBGP-RR1-EXPORT {
        term LOCAL-LOOPBACKS {
            from {
                protocol direct;
                rib inet.3;
                route-filter 0.0.0.0/0 prefix-length-range /32-/32;
            }
            then {
                next-hop self;
                accept;
            }
        }
        term OTHER-BGP {
            from protocol bgp;
            then {
                next-hop self;
                accept;
            }
