chassis {
    redundancy {                                   
        routing-engine 0 master;
        routing-engine 1 backup;
        graceful-switchover;
    }
    routing-engine { 
        on-disk-failure disk-failure-action reboot;
    }
}
routing-options {
    nonstop-routing;
}
{% if snmp is defined %}
snmp {
    engine-id {
        local {{ hostname }};
    }
    {% if snmp_location is defined %}
    location "{{ snmp_location }}";
    {% endif %}
    {% if snmp.contact is defined %}
    contact "{{ snmp.contact }}";
    {% endif %}
    filter-interfaces {
        all-internal-interfaces;
    }
    filter-duplicates;
    trap-options {
        source-address {{ lo0.ip1 }};
    }
    {% if snmp.v2 is defined %}
        {% for cm in snmp.v2.communities %}
    community {{ cm.name }} {
        authorization {{ cm.type }};
        clients {
            {% if cm.clients is defined %}
                {% for ip in cm.clients %}
            {{ ip }};
                {% endfor %}
            0.0.0.0/0 restrict;
            {% else %}
            0.0.0.0/0;
            {% endif %}
        }
    }
        {% endfor %}
        {% if snmp.v2.trap_targets is defined %}
    trap-group TRAPS {
        version v2;
        categories {
            authentication;
            chassis;
            link;
            remote-operations;
            routing;
            startup;
            rmon-alarm;
            vrrp-events;
            configuration;
        }
        targets {
            {% for ip in snmp.v2.targets %}
            {{ ip }};
            {% endfor %}
        }
    }
        {% endif %}{# trap_targets #}
    {% endif %}{# SNMPv2 #}
    {% if snmp.v3 is defined %}
    v3 {
        usm {
            local-engine {
        {% for user in snmp.v3.users %}
                user {{ user.username }} {
                    authentication-sha {
                        authentication-password "{{ user.auth_pwd }}"; 
                    }
                    privacy-aes128 {
                        privacy-password "{{ user.priv_pwd }}";
                    }
                }
        {% endfor %}
            }
        }
        vacm {
            security-to-group {
                security-model usm {
        {% set snmp_groups = [] %}
        {% for user in snmp.v3.users %}
            {% do snmp_groups.append(user.group) %}
                    security-name {{ user.username }} {      # Referenced above, 
                        group {{ user.group }};
                    }
        {% endfor %}
                }
            }
            access {
        {% for group in snmp_groups %}
                group {{ group }} {
                    default-context-prefix {
                        security-model usm {
                            security-level privacy {
                                read-view SNMP_allowed_MIB; 
                                notify-view SNMP_allowed_MIB;
                            }
                        }
                    }
                }
        {% endfor %}
            }
        }
        {% for target in snmp.v3.targets %}
        target-address {{ target.name }} {                 # Label to identify an SNMPv3 client 
            address {{ target.ip }};                       # IP address of the SNMPv3 client
            tag-list TAG_TRAP;                             # Label used to mark a client as SNMPv3 trap receiver
            target-parameters TP-SNMPV3;
        }
        {% endfor %}
        target-parameters TP-SNMPV3 {                      # Parameters of the SNMPv3 client
            parameters {
                message-processing-model v3;
                security-model usm;
                security-level privacy;
                security-name {{ snmp.v3.users[0].username }};           # Username defined within the USM configuration above
            }
            notify-filter TRAP_FILTER;                 # Notification filter, defined below
        }
        notify-filter TRAP_FILTER {                    
            oid .1 include;                                
        }
        notify TRAPS {                                     # Label to identify a trap group
            type trap;
            tag TAG_TRAP;                                  # Tag defined within the "tag-list" above
        }
    }
    {% endif %}{# SNMPv3 #}
    view SNMP_allowed_MIB {
        oid system include;
        oid transmission include;
        oid interfaces include;
        oid ip include;
        oid icmp include;
        oid mgmt include;
        oid tcp include;
        oid udp include;
        oid enterprises include;
        oid dot1dStp include;
        oid vacmContextTable include;
        oid ip.24 exclude;
        oid dot3adAggPortSelectedAggID include;
        oid jnxBgpM2PeerEntry include;
        oid ipMRoute1 include;
    }
}
{% endif %}

