groups {
    GR-BGP-VPN-ADD-PATH-SEND {
        protocols {
            bgp {
                group <*> {
                    family inet-vpn unicast add-path send path-count 2;
                    family inet6-vpn unicast add-path send path-count 2;
                }
            }
        }
    }
    GR-BGP-VPN-ADD-PATH-RECEIVE {
        protocols {
            bgp {
                group <*> {
                    family inet-vpn unicast add-path receive;
                    family inet6-vpn unicast add-path receive;
                }
            }
        }
    }
}
protocols {
    bgp {
        precision-timers;
        path-selection external-router-id;
        snmp-options backward-traps-only-from-established; 
        log-updown; 
    }
}
