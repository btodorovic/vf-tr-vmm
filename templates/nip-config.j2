            term TR-SNMP-udp-ok {
                from {
                    source-prefix-list {
                        PL-snmpv2-community-clients;
                        PL-snmpv3-list-udp;
                    }
                    protocol udp;
                    destination-port snmp;
                }
                then {
                    policer PC-snmp-udp;
                    count CNT-SNMP-udp-ok;
                    accept;
                }
            }
            term TR-NTP-ok {
                from {
                    source-prefix-list {
                        PL-NTP-SERVERS;
                        PL-NTP-SOURCE;
                    }
                    protocol udp;
                    port ntp;
                }
                then {
                    policer PC-ntp;
                    count CNT-NTP-ok;
                    accept;
                }
            }
            term TR-DNS-ok {
                from {
                    source-prefix-list {
                        name-servers;
                    }
                    protocol udp;
                    port domain;
                }
                then {
                    policer PC-dns;
                    count CNT-DNS-ok;
                    accept;
                }
            }
            term TR-ICMP-POLICE-ok {
                from {
                    protocol icmp;
                    icmp-type [ echo-request echo-reply unreachable time-exceeded parameter-problem ];
                }
                then {
                    policer PC-icmp;
                    count CNT-ICMP-POLICE;
                    accept;
                }
            }
            term TR-TRACEROUTE-ok {
                from {
                    protocol udp;
                    destination-port 33434-33523;
                }
                then {
                    policer PC-traceroutes;
                    count CNT-TRACEROUTE-ok;
                    accept;
                }
            }
            term TR-ALL-DISCARD {
                then {
                    count CNT-FF-RE-DISCARD;
                    discard;
                }
            }
        }
    }
    policer PC-TCP-DOS {
        if-exceeding {
            bandwidth-limit 1m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-dns {
        if-exceeding {
            bandwidth-limit 1m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-icmp {
        if-exceeding {
            bandwidth-limit 10m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-igmp {
        if-exceeding {
            bandwidth-limit 1m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-mtrace {
        if-exceeding {
            bandwidth-limit 1m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-netconf {
        if-exceeding {
            bandwidth-limit 10m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-ntp {
        if-exceeding {
            bandwidth-limit 500k;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-pim {
        if-exceeding {
            bandwidth-limit 1m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-snmp-tcp {
        if-exceeding {
            bandwidth-limit 5m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-snmp-udp {
        if-exceeding {
            bandwidth-limit 5m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-ssh {
        if-exceeding {
            bandwidth-limit 50m;
            burst-size-limit 100k;
        }
        then discard;
    }
    policer PC-tacacs {
        if-exceeding {
            bandwidth-limit 1m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-traceroutes {
        if-exceeding {
            bandwidth-limit 1m;
            burst-size-limit 15k;
        }
        then discard;
    }
    policer PC-vrrp {
        if-exceeding {
            bandwidth-limit 1m;
            burst-size-limit 15k;
        }
        then discard;
    }
}
