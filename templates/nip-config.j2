policy-options {
    prefix-list PL-ssh-list {
        /* shadow */
        10.239.96.7/32;
        /* ghost */
        10.152.170.200/32;
        /* CPN4.0 Core Links */
        10.100.40.0/23;
        /* Citrix */
        10.140.232.0/23;
    }
    prefix-list PL-netconf-list {
        /* shadow */
        10.239.96.7/32;
        /* ghost */
        10.152.170.200/32;
        /* CPN4.0 Core Links */
        10.100.40.0/23;
        /* Citrix */
        10.140.232.0/23;
    }
    prefix-list PL-snmpv3-list-tcp {
{% for ip in snmp.v3.clients %}
        {{ ip }};
{% endfor %}
        apply-path "snmp v3 target-address <*> address <*>";
    }
    prefix-list PL-snmpv3-list-udp {
{% for ip in snmp.v3.clients %}
        {{ ip }};
{% endfor %}
        apply-path "snmp v3 target-address <*> address <*>";
    }
    prefix-list PL-snmpv2-community-clients {
        apply-path "snmp community <*> clients <*>";
    }
    prefix-list PL-DEFAULT-V4 {
        0.0.0.0/0;
    }
    prefix-list PL-tacacs-servers {
        apply-path "system tacplus-server <*>";
    }
    prefix-list PL-bgp-peers {
       apply-path "protocols bgp group <*> neighbor <*.*>";
    } 
    prefix-list PL-bgp-peers-vrfs {
       apply-path "routing-instances <*> protocols bgp group <*> neighbor <*.*>";
    } 
    prefix-list PL-LDP-LIST {
        10.100.104.0/24;
        10.255.0.0/16;
        apply-path "interfaces <*> unit <*> family inet address <*>";
    }  
    prefix-list PL-LOOPBACKS {
        10.100.104.0/24;
    }
    prefix-list PL-NTP-SERVERS {
        apply-path "system ntp server <*>";
    }
    prefix-list PL-NTP-SOURCE {
        127.0.0.1/32;
        apply-path "system ntp source-address <*>";
    }
    prefix-list name-servers {
        apply-path "system name-server <*>";
    }
    prefix-list vrrp {
        224.0.0.18/32;
    }
    prefix-list PL-DIRECT-v4 {
        apply-path "interfaces <*> unit <*> family inet address <*>";
    }
    prefix-list PL-DIRECT-V6 { 
        apply-path "interfaces <*> unit <*> family inet6 address <*>";
    }
    prefix-list PL-bgp-peers-vrfs-v6 {
        apply-path "routing-instances <*> protocols bgp group <*> neighbor <*:*>";
    }
}
