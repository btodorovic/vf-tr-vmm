        session {{ ifd.rmt_lo0 }} {
            authentication-key "{{ ldp.key }}";
        }
        {% endif %}{% endfor %}
    {% endif %}
{% for ifd in interfaces %}{% if ifd.isis is defined or ('eTN' in ifd.remote and 'ae' in ifd.ifd) %}
