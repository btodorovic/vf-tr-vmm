groups {
    GR-SYSLOG {                                      # Group template for syslog - common params for syslog servers
        system {
            syslog {
                host <*> {
                    authorization any;
                    cron any;
                    daemon any;
                    kernel any;
                    user any;
                    change-log any;
                    interactive-commands any;
                    facility-override local7;                      # As per current configuration
                    explicit-priority;
                    log-prefix {{ hostname }};                     # Router hostname
                    source-address {{ lo0.ip1 }};                  # Management plane lo0.0 address 
                }
            }
        }
    }
}
